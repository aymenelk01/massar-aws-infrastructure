# Local micro-directories
.terraform/

# Distributed-state lock files
.terraform.lock.hcl

# Local state files (Contains secrets! Never commit these.)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Exclude all variable files (They often contain passwords/tokens)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration credentials
.terraformrc
terraform.rc

# OS clutter and common IDEs
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo